# Grace — environment variables
# Copy to .env and fill in. Do NOT commit .env.
# NOTE: values are read verbatim — do NOT put inline "# comments" after a value;
# keep comments on their own lines like these.

# --- ElevenLabs Agents Platform (voice layer) ---
ELEVENLABS_API_KEY=
ELEVENLABS_INTAKE_AGENT_ID=
ELEVENLABS_QUOTE_AGENT_ID=
ELEVENLABS_NEGO_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=
# Optional. When set, post-call webhooks are HMAC-verified. Leave EMPTY to disable.
ELEVENLABS_WEBHOOK_SECRET=

# --- LLM (extraction, strategy, report) ---
OPENAI_API_KEY=

# --- Research APIs ---
# funeral home name / phone / address
GOOGLE_PLACES_API_KEY=
# local market price research
TAVILY_API_KEY=

# --- Orchestrator ---
# ngrok https URL in dev, Railway URL in prod
BASE_URL=
# ngrok authtoken (from https://dashboard.ngrok.com/get-started/your-authtoken).
# Not read by the app — kept here for convenience / `ngrok config add-authtoken`.
NGROK_AUTH_TOKEN=

# --- Demo ---
# true = swap Places results for teammate phone numbers
DEMO_MODE=false
# comma-separated E.164 numbers, e.g. +14155551234,+16505559876
DEMO_TARGETS=
# auto-cascade research -> quotes -> strategy -> negotiation -> report.
# set false to step each stage manually with POST /cases/{id}/advance.
AUTO_ADVANCE=true
