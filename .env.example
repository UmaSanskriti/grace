# =====================================================================
# Grace — environment template (spec §8.2)
# Copy to .env and fill in AFTER a human creates the accounts (§8.1).
# NEVER commit the filled-in .env. All keys are used server-side only.
# =====================================================================

# --- Twilio (phone/carrier layer) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER_E164=
TWILIO_MESSAGING_WEBHOOK_URL=
TWILIO_STATUS_WEBHOOK_URL=

# --- ElevenLabs (live voice agents) ---
ELEVENLABS_API_KEY=
ELEVENLABS_PHONE_NUMBER_ID=
ELEVENLABS_INTAKE_AGENT_ID=
ELEVENLABS_CALLER_AGENT_ID=
ELEVENLABS_CLOSER_AGENT_ID=
ELEVENLABS_WEBHOOK_SECRET=

# --- OpenAI (structured text intake + normalization/audit) ---
OPENAI_API_KEY=
# Query the account's available models before the build; pin a snapshot
# after golden-call tests. Default to fastest structured-output model.
OPENAI_MODEL_FAST=
OPENAI_MODEL_AUDIT=

# --- Tavily (cached official/fixture research only; never on voice turn path) ---
TAVILY_API_KEY=

# --- Supabase / Lovable Cloud (canonical backend) ---
# Server-side only. Frontend uses the anon key + URL (see web/.env.example).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# 32-byte base64 key used to encrypt phone numbers at rest.
PHONE_ENCRYPTION_KEY=

# --- App / demo controls ---
APP_BASE_URL=
DEMO_ALLOWED_E164=+1..., +1..., +1...
DEMO_RETENTION_HOURS=72
DEMO_MODE=true
DISCLOSURE_VERSION=grace-demo-2026-07-18
