# Grace web — client-side env (Vite exposes only VITE_* vars to the browser).
# Base URL of the Grace FastAPI backend (app/), which serves /agent-activity,
# /call-transcript and /demo-call directly off the root.
VITE_APP_BASE_URL=http://localhost:8000

# SECURITY: NEVER place Twilio / ElevenLabs / OpenAI / Tavily credentials in
# client code. All external APIs are called server-side by the backend; the
# browser holds no credentials at all.
