# Grace web — client-side env (Vite exposes only VITE_* vars to the browser).
# Base URL for the Supabase Edge Functions described in spec §6.3.
VITE_APP_BASE_URL=http://localhost:54321/functions/v1

# Supabase project URL and ANON (publishable) key only.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# SECURITY (spec §10): NEVER place service-role keys or any Twilio / ElevenLabs /
# OpenAI / Tavily credentials in client code. All external APIs are called
# server-side by Edge Functions. Only the anon key belongs here.
